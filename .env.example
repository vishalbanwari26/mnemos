# Copy to .env and fill in.

# Postgres connection used by the app (async driver) and by Alembic (sync driver
# derived automatically — see src/mnemos/config.py).
DATABASE_URL=postgresql+asyncpg://mnemos:mnemos@localhost:5432/mnemos

# STORAGE_BACKEND: postgres | qdrant | neo4j — see "Storage backends" in the README.
# Only affects episodic/semantic memory; procedural memory and the reflection
# log always live in Postgres regardless of this setting.
STORAGE_BACKEND=postgres
QDRANT_LOCAL_PATH=./data/qdrant_local
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=mnemos-neo4j

# Not needed if you only run tests or `--llm mock` mode.
ANTHROPIC_API_KEY=
GROQ_API_KEY=

# LLM_PROVIDER: anthropic | groq | mock
LLM_PROVIDER=anthropic
LLM_MODEL_CHAT=claude-sonnet-4-5-20250929
LLM_MODEL_EXTRACTION=claude-sonnet-4-5-20250929

# Embeddings run locally by default — no API key needed.
EMBEDDING_PROVIDER=local
EMBEDDING_MODEL_NAME=all-MiniLM-L6-v2
EMBEDDING_DIMENSION=384

# Retrieval tuning
RETRIEVAL_TOP_K_SEMANTIC=5
RETRIEVAL_TOP_K_EPISODIC=5
RETRIEVAL_TOP_N=6
RECENCY_HALF_LIFE_DAYS=30
SEMANTIC_DEDUP_THRESHOLD=0.92
EXTRACTION_EVERY_N_TURNS=1

# Reflection (merge/decay/forget) tuning
REFLECTION_MERGE_THRESHOLD=0.80
REFLECTION_DECAY_DAYS=14
REFLECTION_DECAY_FACTOR=0.85
REFLECTION_FORGET_CONFIDENCE_THRESHOLD=0.2

# Procedural memory: exploration rate for epsilon-greedy strategy selection
PROCEDURAL_EPSILON=0.15
